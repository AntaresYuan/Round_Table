NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-local-secret

# Local JSON store. Defaults to ./.roundtable/data.json.
ROUNDTABLE_DATA_PATH=

# Agent dispatch. local-dispatch is deterministic for devrt and CI.
# Set ROUNDTABLE_ENABLE_EXTERNAL_AGENT=1 and ROUNDTABLE_AGENT_ADAPTER=agent-cli
# to orchestrate real local CLIs such as Claude Code or OpenCode.
ROUNDTABLE_AGENT_ADAPTER=agent-cli
ROUNDTABLE_ENABLE_EXTERNAL_AGENT=1
ROUNDTABLE_AGENT_COMMAND=opencode
ROUNDTABLE_AGENT_ARGS=
ROUNDTABLE_AGENT_TIMEOUT_MS=120000

# Optional per-agent / per-role overrides.
# ROUNDTABLE_AGENT_COMMAND_ATLAS=claude
# ROUNDTABLE_AGENT_COMMAND_REVIEWER=opencode
# ROUNDTABLE_AGENT_ARGS_REVIEWER=run "{prompt}"

# DAG scheduler — max review→fix rounds per failed branch (default 2).
ROUNDTABLE_MAX_FIX_ROUNDS=2

# Safety scan of agent artifacts (secrets + dangerous code). Default on.
# Set to false only for testing.
ROUNDTABLE_SAFETY_ENABLED=true

# E2B sandbox (opt-in). Set ROUNDTABLE_AGENT_ADAPTER=e2b to run agent CLIs inside
# an E2B sandbox. If the key is missing, dispatch logs a warning and falls back
# to local-dispatch.
E2B_API_KEY=
